# VoxTics Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control

# Database Configuration
DB_CONNECTION_STRING=Server=db54267.public.databaseasp.net;Database=db54267;User Id=db54267;Password=YOUR_PASSWORD;Encrypt=True;TrustServerCertificate=True;MultipleActiveResultSets=True
DB_PASSWORD=YOUR_DATABASE_PASSWORD

# Email Configuration
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key_here

# Application Settings
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=https://localhost:7244;http://localhost:5018

# Logging
LOG_LEVEL=Warning
